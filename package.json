{
  "name": "vista",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "format": "prettier --write .",
    "check": "pnpm run '/^check:.*/'",
    "check:types": "tsc --noEmit && tsc -p tsconfig.node.json",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "check:test": "vitest run --coverage",
    "check:deadcode": "knip",
    "check:build": "pnpm build",
    "test:unit": "vitest run --project unit",
    "test:contract": "vitest run --project contract",
    "codegen": "node scripts/codegen-furrow-types.mjs"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fast-check/vitest": "^0.4.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-use-encapsulation": "^1.3.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "shadcn": "^4.13.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
