{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // Tailwind IntelliSense inside our cn()/clsx()/twMerge() wrappers — autocomplete,
  // hover, and color swatches on the same class strings better-tailwindcss lints.
  "tailwindCSS.classFunctions": ["cn", "clsx", "twMerge"],
  // Run ESLint autofixes on explicit save, alongside Prettier's formatOnSave.
  // Chief win: better-tailwindcss/enforce-consistent-class-order self-heals the
  // Record maps' class order on save (Prettier can't reach those object values,
  // only className/cn literals), so a mis-order fixes itself instead of only
  // erroring in `pnpm check`. Editor-only — CI still gates via the same rules.
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  }
}
